<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Header: Liquidity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL LIQUIDITY"
            android:textColor="#8e8e93"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00"
            android:textColor="#ffffff"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Mid Row: Inflow / Outflow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="2">

        <!-- Inflow -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_badge_inflow"
            android:padding="8dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ INFLOW"
                android:textColor="#3b82f6"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_inflow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#3b82f6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Outflow -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_badge_outflow"
            android:padding="8dp"
            android:layout_marginStart="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ OUTFLOW"
                android:textColor="#ef4444"
                android:textSize="9sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_outflow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#ef4444"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#28282c"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp" />

    <!-- Bottom Row: Quick Log title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUICK LOG SHORTCUTS"
        android:textColor="#8e8e93"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp" />

    <!-- Quick Log templates container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Template 1: Coffee -->
        <LinearLayout
            android:id="@+id/btn_template_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_button_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Coffee"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹50"
                android:textColor="#8e8e93"
                android:textSize="9sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Template 2: Metro -->
        <LinearLayout
            android:id="@+id/btn_template_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_button_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:layout_marginHorizontal="2dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚇 Metro"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹30"
                android:textColor="#8e8e93"
                android:textSize="9sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Template 3: Grocery -->
        <LinearLayout
            android:id="@+id/btn_template_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_button_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒 Grocery"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹500"
                android:textColor="#8e8e93"
                android:textSize="9sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
